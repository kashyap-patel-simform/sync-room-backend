# Server Configuration
PORT=3000
NODE_ENV=development

# Database
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database-name
# For local MongoDB: mongodb://localhost:27017/database-name
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/room-sync

# Frontend URL (for CORS)
# Used to allow requests only from your frontend domain
FRONTEND_URL=http://localhost:3000

# JWT Secret (CHANGE THIS IN PRODUCTION!)
# Generate a secure random string for production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Logging
LOG_LEVEL=info

# Session Configuration
ROOM_EXPIRY_HOURS=24
SESSION_EXPIRY_HOURS=2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# HTTPS (for production)
HTTPS_ENABLED=false

# mediasoup SFU (WebRTC audio/video)
# Public/LAN IP that ICE candidates should advertise. Leave blank for
# same-machine local dev (loopback works automatically). Set to your LAN IP
# (e.g. 192.168.x.x) to test across devices, or your public IP in production.
MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999
